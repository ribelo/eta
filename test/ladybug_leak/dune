(rule
 (target libladybug_mock.so)
 (deps ladybug_mock_lib.c)
 (action
  (run %{cc} -shared -fPIC -o %{target} %{deps})))

(test
 (name test_ladybug_leak)
 (libraries eta eta_ladybug alcotest eio_main unix)
 (deps
  (:mock libladybug_mock.so))
 (action
  (setenv ETA_LADYBUG_LIBRARY ./%{mock}
   (setenv ETA_LADYBUG_MOCK_STATE ladybug_mock.state
    (run %{test})))))
