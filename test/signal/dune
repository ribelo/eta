(test
 (name test_eta_signal)
 (modules test_eta_signal)
 (libraries eta eta_signal_testable eta_stream eta_eio eta_test alcotest eio_main unix)
 (action
  (setenv EIO_BACKEND posix
   (run %{test}))))

(test
 (name test_eta_signal_public)
 (modules test_eta_signal_public)
 (libraries eta eta_signal eta_stream eta_eio eta_test alcotest eio_main unix)
 (action
  (setenv EIO_BACKEND posix
   (run %{test}))))

(rule
 (alias runtest)
 (deps
  (source_tree negative)
  (:eta_signal_cma ../../lib/signal/eta_signal.cma))
 (action
  (run bash negative/run.sh %{eta_signal_cma})))
