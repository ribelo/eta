=== P-Turso-5 MVCC WAL interaction ===

--- wal_then_mvcc ---
database=/tmp/eta_turso_journal_363040_wal_mvcc.db
open rc=0 msg=not an error
initial pragma=PRAGMA journal_mode rc=0 xrc=0 result=wal msg=not an error
set_wal pragma=PRAGMA journal_mode = 'wal' rc=0 xrc=0 result=wal msg=not an error
then_set_mvcc pragma=PRAGMA journal_mode = 'mvcc' rc=0 xrc=0 result=mvcc msg=not an error
inspect_after_wal_then_mvcc pragma=PRAGMA journal_mode rc=0 xrc=0 result=mvcc msg=not an error
close_after_wal_then_mvcc rc=0

--- mvcc_then_wal ---
open rc=0 msg=not an error
set_mvcc pragma=PRAGMA journal_mode = 'mvcc' rc=0 xrc=0 result=mvcc msg=not an error
then_set_wal pragma=PRAGMA journal_mode = 'wal' rc=0 xrc=0 result=wal msg=not an error
inspect_after_mvcc_then_wal pragma=PRAGMA journal_mode rc=0 xrc=0 result=wal msg=not an error
close_after_mvcc_then_wal rc=0

--- cross_connection ---
conn1_set_mvcc pragma=PRAGMA journal_mode = 'mvcc' rc=0 xrc=0 result=mvcc msg=not an error
conn2_observes pragma=PRAGMA journal_mode rc=0 xrc=0 result=mvcc msg=not an error
cross_connection_close db2_rc=0 db1_rc=0

crash_recovery=Untested blocker=requires external kill harness; in-process fork fixture was unsafe with Turso/Rust library
verdict=Partial
finding=journal_mode is deterministic last-writer-wins; MVCC displaces WAL and WAL displaces MVCC depending on explicit PRAGMA order
