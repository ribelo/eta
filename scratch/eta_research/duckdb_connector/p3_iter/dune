(library
 (name p3_duckdb)
 (modules p3_duckdb)
 (foreign_stubs
  (language c)
  (names p3_iter_stubs)
  (flags :standard (:include c_flags.sexp)))
 (c_library_flags :standard (:include c_library_flags.sexp)))

(executable
 (name p3_iter_probe)
 (modules p3_iter_probe)
 (libraries p3_duckdb unix))

(rule
 (targets c_flags.sexp c_library_flags.sexp)
 (action
  (progn
   (with-stdout-to c_flags.sexp
    (bash "echo '('; pkg-config duckdb --cflags 2>/dev/null || echo '-I'$(dirname $(find /nix/store -maxdepth 4 -name duckdb.h -path '*/include/*' 2>/dev/null | head -1)) | tr ' ' '\n'; echo ')'"))
   (with-stdout-to c_library_flags.sexp
    (bash "echo '('; pkg-config duckdb --libs 2>/dev/null || echo '-L'$(dirname $(find /nix/store -maxdepth 4 -name libduckdb.so 2>/dev/null | head -1))' -lduckdb' | tr ' ' '\n'; echo ')'")))))
