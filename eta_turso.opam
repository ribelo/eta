  "dune" {>= "3.21"}
  "ocaml" {>= "5.2.0"}
  "eta"
  "eta_blocking"
  "eta_sql_driver"
  "eta_sql"
  "eta_sql_dsl"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
