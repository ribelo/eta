opam-version: "2.0"
synopsis: "Testing helpers for Eta"
description:
  "eta_test provides virtual clocks, deterministic random values, and Alcotest helpers for Eta programs."
depends: [
  "ocaml" {= "5.2.0"}
  "ocaml-variants" {= "5.2.0+ox"}
  "dune" {>= "3.21" & >= "3.0"}
  "eta"
  "eio" {>= "1.0"}
  "eio_main" {>= "1.0"}
  "alcotest"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
