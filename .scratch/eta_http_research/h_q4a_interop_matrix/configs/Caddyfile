{
  admin off
  auto_https off
  servers {
    protocols h1 h2 h2c
  }
}

(common) {
  root * {$WWW_DIR}

  handle /ok {
    respond "caddy-ok\n" 200
  }

  handle /redirect {
    redir /ok 302
  }

  handle /empty {
    respond "" 200
  }

  handle /head {
    respond "head-body" 200
  }

  handle /early413 {
    request_body {
      max_size 1B
    }
    respond "accepted\n" 200
  }

  handle /sse {
    header Content-Type text/event-stream
    respond ":\n\ndata: heartbeat\n\n" 200
  }

  handle /ws {
    respond "upgrade rejected\n" 426
  }

  file_server
}

http://127.0.0.1:{$CADDY_HTTP_PORT} {
  import common
}

https://127.0.0.1:{$CADDY_HTTPS_PORT} {
  tls {$CERT_FILE} {$KEY_FILE}
  import common
}
