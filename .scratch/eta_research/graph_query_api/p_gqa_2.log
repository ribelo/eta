D.optional_match=Clean expr=raw Cypher string
E.optional_match=Clean expr=optional reusable fragment

feature=anonymous_nodes cypher=(a)-[:REL]->()
B.anonymous_nodes=Clean expr=anon_node ()
C.anonymous_nodes=Clean expr=literal syntax is native
D.anonymous_nodes=Clean expr=raw Cypher string
E.anonymous_nodes=Awkward expr=fragment must expose anonymous endpoint

feature=bidirectional cypher=(a)-[r]-(b)
B.bidirectional=Clean expr=rel r ~dir:Either
C.bidirectional=Clean expr=literal syntax is native
D.bidirectional=Clean expr=raw Cypher string
E.bidirectional=Awkward expr=requires a separate undirected fragment

feature=named_path cypher=path = (a)-[*]->(b)
B.named_path=Clean expr=path name pattern
C.named_path=Clean expr=literal syntax is native
D.named_path=Clean expr=raw Cypher string
E.named_path=Clean expr=path fragment returns path binding

verdict=Branch B covers all pattern features cleanly; Branch E is useful for named fragments but awkward for anonymous and bidirectional one-offs; Branch C/D trivially preserve Cypher syntax.
surprise=Pattern composition is graph-shaped, not SQL-shaped: Branch B survives because it stops trying to make the pattern itself a pipe.
