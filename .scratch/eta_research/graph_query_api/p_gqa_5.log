return_node_count.tuple=Clean type=Person.t * int64
return_node_count.record=Clean type={ p : Person.t; n : int64 }
return_node_count.hlist=Awkward type=Person.t @ int64 @ nil

verdict=Tuple decoder is the smallest primary shape; generated records are useful optional sugar when aliases matter; hlist/applicative shape is too ceremonial for the three tested queries.
surprise=Generated records help most for multi-column scalar returns, not for RETURN p.
