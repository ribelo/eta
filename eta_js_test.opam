depends: [
  "dune" {>= "3.21"}
  "ocaml" {>= "5.2.0"}
  "eta_js"
  "js_of_ocaml" {>= "5.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
