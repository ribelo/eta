opam-version: "2.0"
synopsis: "Testing helpers for Eta"
description:
  "Provides Eta-shaped testing helpers: a virtual-time test clock, deterministic random tokens, and cause assertion helpers."
depends: [
  "ocaml" {= "5.2.0+ox"}
  "dune" {>= "3.21" & >= "3.0"}
  "eta" {= version}
  "eio" {>= "1.0"}
  "eio_main" {>= "1.0"}
  "alcotest"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
